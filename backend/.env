# Obtain credentials from https://brandbox.co.tz
BRANDBOX_API_KEY=VBJciqtAfds9pOKMW5fbbdYKkdTDCqdU
BRANDBOX_API_SECRET=MGvvvFHZGapjDiPgiNh62lPHWaYjvmeNuM1h1FuyVoI17sGBdvrGVRR8cNH07DGs

# Sender name shown on SMS messages (max 11 characters)
BRANDBOX_SENDER_NAME=TPFCS
